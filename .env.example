# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zkteco
DB_USER=postgres
DB_PASSWORD=

# ── Device passwords (leave empty if the device has no password set) ──────────
DEVICE_PASSWORD_ATTN1=
DEVICE_PASSWORD_ATTN2=
DEVICE_PASSWORD_ATN3=

# ── Company / Report header ───────────────────────────────────────────────────
COMPANY_NAME=My Organization
COMPANY_ADDRESS=City, Country
COMPANY_EMAIL=info@example.org
COMPANY_WEBSITE=www.example.org

# ── Timezones ─────────────────────────────────────────────────────────────────
# Timezone the physical ZKTeco devices are set to (for timestamp localisation)
# Examples: UTC  |  Asia/Dhaka  |  Asia/Kathmandu  |  Asia/Karachi
DEVICE_TIMEZONE=Asia/Kathmandu

# Timezone used to interpret the pull schedule (06:20, 07:20, 09:20, 13:20, 17:10)
# Set this to the local timezone of the server
# Examples: UTC  |  Asia/Dhaka  |  Asia/Kathmandu  |  Asia/Karachi
SCHEDULER_TIMEZONE=Asia/Kathmandu
